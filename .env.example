# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your own values.
# Never commit the real .env file — it's already in .gitignore.
# ---------------------------------------------------------------------------

# PostgreSQL connection string (Prisma). Works with Supabase / Neon / Railway /
# local Postgres. Example local: postgresql://postgres:postgres@localhost:5432/collab_editor
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/collab_editor?schema=public"

# If you'd rather use MongoDB Atlas instead of Postgres for the document-update
# log (the append-only CRDT update log is schema-light and works fine on either
# store — see README "Swapping Postgres for MongoDB"), paste your connection
# string here and set STORAGE_DRIVER=mongo below.
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/collab_editor?retryWrites=true&w=majority"

# Which driver the sync log + snapshot store use: "postgres" (default, via
# Prisma, required for the RLS/tenant-isolation features) or "mongo".
STORAGE_DRIVER="postgres"

# Auth.js / NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="8463148be7c569e23bb8e9ffec31d39b493e4e8ca6937753631910f6ab5dd3e0"
# Realtime relay (custom lightweight ws server in /server/ws-server.ts)
NEXT_PUBLIC_WS_URL="ws://localhost:1234"

# AI add-on features (pick whichever provider you have a key for; the AI
# client in src/lib/ai/client.ts auto-detects which one is set)
OPENAI_API_KEY=""
GROQ_API_KEY=""

# Max size (bytes) accepted for a single sync payload before the API rejects
# it with 413 — this is the primary OOM mitigation, see README "Security".
MAX_SYNC_PAYLOAD_BYTES=2000000
